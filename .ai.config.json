{
  "adapters": {
    "claude-code": {}
  },
  "plugins": {
    "logger": {}
  },
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--headless",
        "--isolated",
        "--viewport",
        "1920x934"
      ]
    }
  },
  "permissions": {
    "allow": [],
    "deny": [],
    "ask": [
      "Bash(kill:*)",
      "Bash(chmod:*)"
    ]
  },
  "announcements": [
    "欢迎使用 AI 时代的代码工业机床。"
  ],
  "shortcuts": {
    "openConfig": "mod+,",
    "sendMessage": "mod+enter",
    "clearInput": "escape",
    "newSession": "mod+k"
  }
}
