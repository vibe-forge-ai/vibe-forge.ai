{
  "adapters": {
    "claude-code": {
      "ccrTransformers": {
        "logger": true
      }
    },
    "codex": {},
    "kimi": {},
    "opencode": {}
  },
  "plugins": [
    {
      "id": "logger"
    },
    {
      "id": "standard-dev",
      "scope": "std"
    }
  ],
  "modelServices": {
    "hook-smoke-mock": {
      "title": "Hook Smoke Mock",
      "description": "Local offline mock LLM service for hook smoke tests.",
      "apiBaseUrl": "http://127.0.0.1:${HOOK_SMOKE_MOCK_PORT}/responses",
      "apiKey": "hook-smoke-local",
      "models": ["codex-hooks", "claude-hooks", "opencode-hooks"],
      "extra": {
        "codex": {
          "wireApi": "responses"
        },
        "opencode": {
          "wireApi": "responses"
        }
      }
    },
    "hook-smoke-mock-ccr": {
      "title": "Hook Smoke Mock CCR",
      "description": "Local offline mock LLM service for Claude Code Router smoke tests.",
      "apiBaseUrl": "http://127.0.0.1:${HOOK_SMOKE_MOCK_PORT}/chat/completions",
      "apiKey": "hook-smoke-local",
      "models": ["claude-hooks"]
    }
  },
  "mcpServers": {
    "ChromeDevtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--headless",
        "--isolated",
        "--viewport",
        "1920x934"
      ]
    }
  },
  "permissions": {
    "allow": ["ChromeDevtools"],
    "deny": [],
    "ask": ["Bash(kill:*)", "Bash(chmod:*)"]
  },
  "announcements": ["欢迎使用 AI 时代的代码工业机床。"],
  "shortcuts": {
    "openConfig": "mod+,",
    "sendMessage": "mod+enter",
    "clearInput": "escape",
    "newSession": "mod+k"
  }
}
