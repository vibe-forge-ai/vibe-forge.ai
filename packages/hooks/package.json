{
  "name": "@vibe-forge/hooks",
  "version": "0.10.0",
  "description": "Vibe Forge hooks runtime and bridge helpers",
  "imports": {
    "#~/*.js": {
      "__vibe-forge__": {
        "default": "./src/*.ts"
      },
      "default": {
        "import": "./dist/*.mjs",
        "require": "./dist/*.js"
      }
    }
  },
  "exports": {
    ".": {
      "__vibe-forge__": {
        "default": "./src/index.ts"
      },
      "default": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.js"
      }
    },
    "./claude-json-plugin": {
      "__vibe-forge__": {
        "default": "./src/claude-json-plugin.ts"
      },
      "default": {
        "import": "./dist/claude-json-plugin.mjs",
        "require": "./dist/claude-json-plugin.js"
      }
    },
    "./call-hook.js": "./call-hook.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "vf-call-hook": "./call-hook.js"
  },
  "scripts": {
    "test": "pnpm -C ../.. exec vitest run --workspace vitest.workspace.ts --project bundler packages/hooks/__tests__"
  },
  "dependencies": {
    "@vibe-forge/config": "workspace:^",
    "@vibe-forge/register": "workspace:^",
    "@vibe-forge/types": "workspace:^",
    "@vibe-forge/utils": "workspace:^"
  },
  "devDependencies": {
    "fast-glob": "^3.3.3"
  }
}
