{
  "name": "@vibe-forge/channel-lark",
  "version": "0.9.0",
  "imports": {
    "#~/*.js": {
      "__vibe-forge__": {
        "default": "./src/*.ts"
      },
      "default": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.js"
      }
    }
  },
  "exports": {
    ".": {
      "__vibe-forge__": {
        "default": "./src/index.ts"
      },
      "default": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.js"
      }
    },
    "./connection": {
      "__vibe-forge__": {
        "default": "./src/connection.ts"
      },
      "default": {
        "import": "./dist/connection.mjs",
        "require": "./dist/connection.js"
      }
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "latest",
    "@vibe-forge/core": "workspace:^",
    "zod": "^3.24.1"
  }
}
