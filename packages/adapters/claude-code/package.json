{
  "name": "@vibe-forge/adapter-claude-code",
  "version": "1.0.1",
  "description": "Claude Code Adapter for Vibe Forge",
  "exports": {
    ".": {
      "__vibe-forge__": {
        "default": "./src/index.ts"
      },
      "default": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.js"
      }
    },
    "./schema": {
      "__vibe-forge__": {
        "default": "./src/schema.ts"
      },
      "default": {
        "import": "./dist/schema.mjs",
        "require": "./dist/schema.js"
      }
    },
    "./models": {
      "__vibe-forge__": {
        "default": "./src/models.ts"
      },
      "default": {
        "import": "./dist/models.mjs",
        "require": "./dist/models.js"
      }
    },
    "./icon": {
      "__vibe-forge__": {
        "default": "./src/icon.ts"
      },
      "default": {
        "import": "./dist/icon.mjs",
        "require": "./dist/icon.js"
      }
    },
    "./hook-bridge": {
      "__vibe-forge__": {
        "default": "./src/hooks/bridge.ts"
      },
      "default": {
        "import": "./dist/hooks/bridge.mjs",
        "require": "./dist/hooks/bridge.js"
      }
    },
    "./plugins": {
      "__vibe-forge__": {
        "default": "./src/plugins/index.ts"
      },
      "default": {
        "import": "./dist/plugins/index.mjs",
        "require": "./dist/plugins/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "2.1.109",
    "@musistudio/claude-code-router": "1.0.73",
    "@vibe-forge/config": "workspace:^",
    "@vibe-forge/core": "workspace:^",
    "@vibe-forge/hooks": "workspace:^",
    "@vibe-forge/types": "workspace:^",
    "@vibe-forge/utils": "workspace:^"
  }
}
