{
  "name": "@vibe-forge/managed-plugins",
  "version": "3.0.0-alpha.1",
  "description": "Managed native plugin installation and sync for Vibe Forge",
  "imports": {
    "#~/*.js": {
      "__vibe-forge__": {
        "default": "./src/*.ts"
      },
      "default": {
        "import": "./dist/*.mjs",
        "require": "./dist/*.js"
      }
    }
  },
  "exports": {
    ".": {
      "__vibe-forge__": {
        "default": "./src/index.ts"
      },
      "default": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "pnpm -C ../.. exec vitest run --workspace vitest.workspace.ts --project bundler packages/managed-plugins/__tests__"
  },
  "dependencies": {
    "@vibe-forge/types": "workspace:*",
    "@vibe-forge/utils": "workspace:*"
  }
}
