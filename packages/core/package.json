{
  "name": "@vibe-forge/core",
  "version": "0.7.5",
  "imports": {
    "#~/*.js": {
      "__vibe-forge__": {
        "default": "./src/*.ts"
      },
      "default": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.js"
      }
    }
  },
  "exports": {
    ".": {
      "__vibe-forge__": {
        "default": "./src/index.ts"
      },
      "default": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.js"
      }
    },
    "./adapter": {
      "__vibe-forge__": {
        "default": "./src/adapter/index.ts"
      },
      "default": {
        "import": "./dist/adapter.mjs",
        "require": "./dist/adapter.js"
      }
    },
    "./channel": {
      "__vibe-forge__": {
        "default": "./src/channel.ts"
      },
      "default": {
        "import": "./dist/channel.mjs",
        "require": "./dist/channel.js"
      }
    },
    "./schema": {
      "__vibe-forge__": {
        "default": "./src/schema.ts"
      },
      "default": {
        "import": "./dist/schema.mjs",
        "require": "./dist/schema.js"
      }
    },
    "./hooks": {
      "__vibe-forge__": {
        "default": "./src/hooks/index.ts"
      },
      "default": {
        "import": "./dist/hooks/index.mjs",
        "require": "./dist/hooks/index.js"
      }
    },
    "./call-hook.js": "./call-hook.js",
    "./utils/*": {
      "__vibe-forge__": {
        "default": "./src/utils/*.ts"
      },
      "default": {
        "import": "./dist/utils/*.mjs",
        "require": "./dist/utils/*.js"
      }
    },
    "./controllers/*": {
      "__vibe-forge__": {
        "default": "./src/controllers/*/index.ts"
      },
      "default": {
        "import": "./dist/controllers/*/index.mjs",
        "require": "./dist/controllers/*/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@vibe-forge/register": "workspace:^",
    "fast-glob": "^3.3.3",
    "front-matter": "^4.0.2",
    "js-yaml": "^4.1.1",
    "node-notifier": "^10.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node-notifier": "^8.0.5"
  }
}
