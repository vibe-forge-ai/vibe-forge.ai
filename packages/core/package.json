{
  "name": "@vibe-forge/core",
  "version": "3.0.0-alpha.0",
  "imports": {
    "#~/*.js": {
      "__vibe-forge__": {
        "default": "./src/*.ts"
      },
      "default": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.js"
      }
    }
  },
  "exports": {
    ".": {
      "__vibe-forge__": {
        "default": "./src/index.ts"
      },
      "default": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.js"
      }
    },
    "./channel": {
      "__vibe-forge__": {
        "default": "./src/channel.ts"
      },
      "default": {
        "import": "./dist/channel.mjs",
        "require": "./dist/channel.js"
      }
    },
    "./config-schema": {
      "__vibe-forge__": {
        "default": "./src/config-schema.ts"
      },
      "default": {
        "import": "./dist/config-schema.mjs",
        "require": "./dist/config-schema.js"
      }
    },
    "./schema": {
      "__vibe-forge__": {
        "default": "./src/schema.ts"
      },
      "default": {
        "import": "./dist/schema.mjs",
        "require": "./dist/schema.js"
      }
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@vibe-forge/types": "workspace:*",
    "@vibe-forge/utils": "workspace:*",
    "zod": "^3.24.1"
  }
}
