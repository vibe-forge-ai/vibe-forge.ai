{
  "name": "@vibe-forge/tool-view",
  "version": "0.1.0",
  "description": "Shared tool view contracts and generic builders for Vibe Forge",
  "imports": {
    "#~/*.js": {
      "__vibe-forge__": {
        "default": "./src/*.ts"
      },
      "default": {
        "import": "./dist/*.mjs",
        "require": "./dist/*.js"
      }
    }
  },
  "exports": {
    ".": {
      "__vibe-forge__": {
        "default": "./src/index.ts"
      },
      "default": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "pnpm -C ../.. exec vitest run --workspace vitest.workspace.ts --project bundler packages/tool-view/__tests__"
  },
  "dependencies": {
    "@vibe-forge/types": "workspace:^"
  }
}
