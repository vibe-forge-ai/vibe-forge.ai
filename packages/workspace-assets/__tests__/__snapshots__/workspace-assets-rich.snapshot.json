      {
        "id": "nativePlugin:claude-code:logger",
        "kind": "nativePlugin",
        "origin": "config",
        "scope": "project",
        "pluginId": "logger",
        "enabled": true,
        "targets": [
          "claude-code"
        ],
        "name": "logger"
