    "opencodeOverlayAssets": [
      {
        "id": "agent:.ai/plugins/demo/opencode/agents/release-helper.md",
        "kind": "agent",
        "origin": "plugin",
        "scope": "workspace",
        "pluginId": "demo",
        "enabled": true,
        "targets": [
          "opencode"
