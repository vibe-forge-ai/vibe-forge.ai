{
  "bundle": {
    "cwd": "<workspace>",
    "enabledPlugins": {
      "demo": true,
      "legacy": false,
      "logger": true,
      "telemetry": true
    },
    "extraKnownMarketplaces": {
      "internal": {
        "source": {
          "source": "git",
          "url": "https://plugins.internal.example.com"
        }
      }
    },
    "defaultIncludeMcpServers": [
      "browser",
      "docs"
    ],
    "defaultExcludeMcpServers": [
      "notes"
    ],
    "rules": [
      {
        "id": "rule:.ai/rules/review.md",
        "kind": "rule",
        "origin": "project",
        "scope": "workspace",
        "enabled": true,
        "targets": [
          "claude-code",
          "codex",
          "opencode"
        ],
        "definition": {
          "identifier": "review",
          "path": "<workspace>/.ai/rules/review.md",
          "attributes": {
            "always": true,
            "description": "项目评审规则"
          },
          "body": "必须检查发布改动的回归风险。"
        }
      },
      {
        "id": "rule:.ai/plugins/demo/rules/security.md",
        "kind": "rule",
        "origin": "plugin",
        "scope": "workspace",
        "pluginId": "demo",
        "enabled": true,
        "targets": [
          "claude-code",
          "codex",
          "opencode"
        ],
        "definition": {
          "identifier": "security",
          "path": "<workspace>/.ai/plugins/demo/rules/security.md",
          "attributes": {
            "description": "插件安全规则"
          },
          "body": "上线前要检查权限与密钥暴露。"
        }
      }
    ],
    "specs": [
      {
        "id": "spec:.ai/specs/release/index.md",
        "kind": "spec",
        "origin": "project",
        "scope": "workspace",
        "enabled": true,
        "targets": [
          "claude-code",
          "codex",
          "opencode"
        ],
        "definition": {
          "identifier": "release",
          "path": "<workspace>/.ai/specs/release/index.md",
          "attributes": {
            "description": "正式发布流程",
            "mcpServers": {
              "exclude": [
                "browser"
              ],
              "include": [
                "docs",
                "browser"
              ]
            },
            "rules": [
              ".ai/rules/review.md"
            ],
            "skills": [
              "research"
            ],
            "tools": {
              "include": [
                "Read",
                "Edit"
              ]
            }
          },
          "body": "执行正式发布，并整理变更摘要。"
        }
      }
    ],
    "entities": [
      {
        "id": "entity:.ai/entities/architect/README.md",
        "kind": "entity",
        "origin": "project",
        "scope": "workspace",
        "enabled": true,
        "targets": [
          "claude-code",
          "codex",
          "opencode"
        ],
        "definition": {
          "identifier": "architect",
          "path": "<workspace>/.ai/entities/architect/README.md",
          "attributes": {
            "description": "负责拆解方案的实体"
          },
          "body": "把发布任务拆解成执行步骤。"
        }
      }
    ],
    "skills": [
      {
        "id": "skill:.ai/skills/research/SKILL.md",
        "kind": "skill",
        "origin": "project",
        "scope": "workspace",
        "enabled": true,
        "targets": [
          "claude-code",
          "codex",
          "opencode"
        ],
        "definition": {
          "identifier": "research",
          "path": "<workspace>/.ai/skills/research/SKILL.md",
          "attributes": {
            "description": "检索资料"
          },
          "body": "先阅读 README.md，再补充结论。"
        }
      },
      {
        "id": "skill:.ai/plugins/demo/skills/audit/SKILL.md",
        "kind": "skill",
        "origin": "plugin",
        "scope": "workspace",
        "pluginId": "demo",
        "enabled": true,
        "targets": [
          "claude-code",
          "codex",
          "opencode"
        ],
        "definition": {
          "identifier": "audit",
          "path": "<workspace>/.ai/plugins/demo/skills/audit/SKILL.md",
          "attributes": {
            "description": "审计输出"
