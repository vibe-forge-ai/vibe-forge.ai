    "mcpServers": [
      {
        "id": "mcpServer:.ai/plugins/demo/mcp/browser.json",
        "origin": "plugin",
        "scope": "workspace",
        "pluginId": "demo",
        "enabled": true,
        "targets": [
          "claude-code",
          "codex",
          "opencode"
        ],
        "name": "browser",
        "config": {
          "args": [
            "browser-mcp"
          ],
          "command": "npx"
        }
      },
      {
        "id": "mcpServer:project:docs",
        "origin": "config",
        "scope": "project",
