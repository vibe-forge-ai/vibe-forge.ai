        "scope": "user",
        "enabled": true,
        "targets": [
          "claude-code",
          "codex",
          "opencode"
        ],
        "name": "notes",
        "config": {
          "args": [
            "tools/notes-mcp.js"
          ],
          "command": "node"
        }
      }
    ],
    "hookPlugins": [
      {
        "id": "hookPlugin:project:logger",
        "origin": "config",
        "scope": "project",
        "pluginId": "logger",
        "enabled": true,
        "targets": [
          "claude-code",
          "codex",
          "opencode"
        ],
        "packageName": "logger",
        "config": {
          "level": "info"
        }
      },
      {
        "id": "hookPlugin:user:telemetry",
        "origin": "config",
        "scope": "user",
        "pluginId": "telemetry",
        "enabled": true,
        "targets": [
          "claude-code",
          "codex",
          "opencode"
        ],
        "packageName": "telemetry",
        "config": {
          "mode": "summary"
        }
      }
    ],
    "claudeNativePlugins": [
      {
        "id": "nativePlugin:claude-code:demo",
        "kind": "nativePlugin",
        "origin": "config",
        "scope": "project",
        "pluginId": "demo",
        "enabled": true,
        "targets": [
          "claude-code"
        ],
        "name": "demo"
      },
      {
        "id": "nativePlugin:claude-code:legacy",
        "kind": "nativePlugin",
        "origin": "config",
        "scope": "project",
        "pluginId": "legacy",
        "enabled": false,
        "targets": [
          "claude-code"
        ],
        "name": "legacy"
