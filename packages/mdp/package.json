{
  "name": "@vibe-forge/mdp",
  "version": "1.0.0",
  "description": "Model Drive Protocol integration for Vibe Forge",
  "imports": {
    "#~/*.js": {
      "__vibe-forge__": {
        "default": "./src/*.ts"
      },
      "default": {
        "import": "./dist/*.mjs",
        "require": "./dist/*.js"
      }
    }
  },
  "exports": {
    ".": {
      "__vibe-forge__": {
        "default": "./src/index.ts"
      },
      "default": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.js"
      }
    },
    "./browser": {
      "__vibe-forge__": {
        "default": "./src/browser.ts"
      },
      "default": {
        "import": "./dist/browser.mjs",
        "require": "./dist/browser.js"
      }
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "vibe-forge-mdp": "./cli.js",
    "vf-mdp": "./cli.js"
  },
  "scripts": {
    "test": "pnpm -C ../.. exec vitest run --workspace vitest.workspace.ts --project bundler packages/mdp/__tests__"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@modeldriveprotocol/client": "^2.2.0",
    "@modeldriveprotocol/server": "^2.2.0",
    "@vibe-forge/cli-helper": "workspace:^",
    "@vibe-forge/config": "workspace:^",
    "@vibe-forge/types": "workspace:^",
    "@vibe-forge/utils": "workspace:^",
    "@vibe-forge/workspace-assets": "workspace:^"
  }
}
