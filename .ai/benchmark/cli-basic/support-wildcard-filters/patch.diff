+const matchesFilterValue = (name: string, value: string) => {
+  if (value === '*') return true
+  if (value.endsWith('*')) {
+    return name.startsWith(value.slice(0, -1))
+  }
+  return name === value
+}
+
+const matchesFilterList = (name: string, values: string[]) => {
+  return values.some(value => matchesFilterValue(name, value))
+}
