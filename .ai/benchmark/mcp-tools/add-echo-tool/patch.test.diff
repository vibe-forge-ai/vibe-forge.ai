+
+  describe('echo tool', () => {
+    it('should register echo tool', () => {
+      const tester = createToolTester()
+      echo(tester.mockRegister)
+
+      expect(tester.getRegisteredTools()).toContain('echo')
+      const info = tester.getToolInfo('echo')
+      expect(info?.title).toBe('Echo Tool')
+    })
+
+    it('should return echoed message with prefix', async () => {
+      const tester = createToolTester()
+      echo(tester.mockRegister)
+
+      const result = await tester.callTool('echo', { message: 'hello world' }) as any
+      expect(result.content[0].text).toBe('Echo: hello world')
+    })
+
+    it('should fail validation when message is missing', async () => {
+      const tester = createToolTester()
+      echo(tester.mockRegister)
+
