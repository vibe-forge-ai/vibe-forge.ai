{
  "name": "@vibe-forge/cli",
  "version": "0.10.1",
  "description": "Vibe Forge CLI",
  "imports": {
    "#~/*.js": {
      "__vibe-forge__": {
        "default": "./src/*.ts"
      }
    }
  },
  "exports": {
    "./package.json": "./package.json",
    "./config": {
      "__vibe-forge__": {
        "default": "./src/config.ts"
      },
      "default": {
        "import": "./dist/config.mjs",
        "require": "./dist/config.js"
      }
    }
  },
  "bin": {
    "vibe-forge": "./cli.js",
    "vforge": "./cli.js",
    "vf": "./cli.js"
  },
  "scripts": {
    "test": "pnpm -C ../.. exec vitest run --workspace vitest.workspace.ts --project node apps/cli/__tests__"
  },
  "dependencies": {
    "@vibe-forge/app-runtime": "workspace:^",
    "@vibe-forge/cli-helper": "workspace:^",
    "@vibe-forge/config": "workspace:^",
    "@vibe-forge/core": "workspace:^",
    "@vibe-forge/hooks": "workspace:^",
    "@vibe-forge/register": "workspace:^",
    "@vibe-forge/types": "workspace:^",
    "@vibe-forge/utils": "workspace:^",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.3",
    "node-notifier": "^10.0.1"
  },
  "devDependencies": {
    "@types/node-notifier": "^8.0.5"
  }
}
