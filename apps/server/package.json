{
  "name": "@vibe-forge/server",
  "version": "2.0.1",
  "description": "Vibe Forge server",
  "imports": {
    "#~/*.js": {
      "__vibe-forge__": {
        "default": "./src/*.ts"
      },
      "default": {
        "import": "./dist/__INTERNAL__home/*.mjs",
        "require": "./dist/__INTERNAL__home/*.js"
      }
    }
  },
  "exports": {
    "./cli-runtime": {
      "__vibe-forge__": {
        "default": "./src/cli-runtime.ts"
      },
      "default": {
        "import": "./dist/cli-runtime.mjs",
        "require": "./dist/cli-runtime.js"
      }
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "vibe-forge-server": "./cli.js"
  },
  "dependencies": {
    "@koa/cors": "^5.0.0",
    "@koa/router": "^12.0.0",
    "@vibe-forge/adapter-claude-code": "workspace:^",
    "@vibe-forge/app-runtime": "workspace:^",
    "@vibe-forge/channel-lark": "workspace:^",
    "@vibe-forge/cli-helper": "workspace:^",
    "@vibe-forge/config": "workspace:^2.0.2",
    "@vibe-forge/core": "workspace:^",
    "@vibe-forge/definition-core": "workspace:^",
    "@vibe-forge/definition-loader": "workspace:^",
    "@vibe-forge/managed-plugins": "workspace:^",
    "@vibe-forge/register": "workspace:^",
    "@vibe-forge/types": "workspace:^",
    "@vibe-forge/utils": "workspace:^",
    "commander": "^12.1.0",
    "cron-parser": "^4.9.0",
    "koa": "^2.15.0",
    "koa-bodyparser": "^4.3.0",
    "koa-send": "^5.0.1",
    "node-pty": "^1.1.0",
    "pino": "^10.2.0",
    "pino-pretty": "^13.1.3",
    "uuid": "^9.0.1",
    "ws": "^8.17.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/koa": "^3.0.1",
    "@types/koa-bodyparser": "^4.3.13",
    "@types/koa-send": "^4.1.5",
    "@types/koa__cors": "^5.0.1",
    "@types/koa__router": "^12.0.5",
    "@types/node": "^22.18.12",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.18.1"
  }
}
